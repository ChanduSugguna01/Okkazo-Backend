# Server Configuration
PORT=8084
NODE_ENV=development
SERVICE_NAME=vendor-service
SERVICE_HOST=vendor-service

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/okkazo_vendor_db

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=vendor-service
KAFKA_GROUP_ID=vendor-service-group
KAFKA_TOPIC=vendor_events

# Eureka Configuration
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_REGISTER_WITH_EUREKA=true

# Cloudinary Configuration (for document uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=okkazo/vendor-documents
